{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://neon-ticket-five.vercel.app/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "https://neon-ticket-five.vercel.app/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
