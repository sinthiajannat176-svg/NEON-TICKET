{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://n4.nexcloud.in:2037/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "http://n4.nexcloud.in:2037/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
