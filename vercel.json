{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://NEON-TICKET/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "https://NEON-TICKET/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
